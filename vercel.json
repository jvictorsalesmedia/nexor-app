{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      },
      "continue": true
    },
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "^/app$", "dest": "/index.html" },
    { "src": "^/cliente/(.*)$", "dest": "/index.html" },
    { "handle": "filesystem" }
  ]
}
