SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Use somente no servidor: Vercel API ou Supabase Edge Function.
# Nao exponha no navegador e nao coloque como NEXT_PUBLIC/VITE.
SUPABASE_SERVICE_ROLE_KEY=
# Fallback usado pelo codigo em api/*.js quando SUPABASE_SERVICE_ROLE_KEY nao
# esta definida (chave "secret" do novo formato de chaves do Supabase).
SUPABASE_SECRET_KEY=

# Compatibilidade com builds Vite, se voce migrar o app depois.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Opcional: usado como redirect_to dos emails de convite/recuperacao de senha
# (api/admin-client.js) quando os headers origin/host da requisicao Vercel nao
# vierem preenchidos. Ex: https://app.seudominio.com
PUBLIC_SITE_URL=

GOOGLE_OAUTH_CLIENT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Usado por api/nex-ai.js (botao "Nex AI" no topo do app) para interpretar
# texto livre e criar tarefa/lead/financeiro automaticamente. Chave gratuita
# gerada em aistudio.google.com/apikey. A mesma chave tambem e usada como
# secret separada (GEMINI_API_KEY) no Edge Function whatsapp-webhook do
# Supabase — sao dois lugares diferentes, precisa configurar nos dois.
GEMINI_API_KEY=

# Usado por api/admin-client.js (sendApprovalEmail) para avisar por email
# quando um pre-cadastro e aprovado. GMAIL_APP_PASSWORD e a "senha de app"
# do Gmail (gerada com a Verificacao em duas etapas ativada), nao a senha
# normal da conta.
GMAIL_USER=
GMAIL_APP_PASSWORD=
